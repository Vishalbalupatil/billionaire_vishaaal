# =========================================================
# Billionaire Vishaaal - AI Trading Platform
# Example environment configuration.
# Copy to .env and fill in real values. NEVER commit .env.
# =========================================================

# -------- Zerodha Kite Connect --------
# Create an app at https://kite.trade/ to obtain these values.
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# Access token is generated daily via the login flow (see README).
KITE_ACCESS_TOKEN=
# User id (e.g. AB1234) - used for display/audit only.
KITE_USER_ID=

# -------- App mode --------
# One of: analysis | paper | live
# Default is analysis. "live" ALSO requires LIVE_TRADING_UNLOCK=I_UNDERSTAND_THE_RISKS.
APP_MODE=analysis
LIVE_TRADING_UNLOCK=

# -------- Capital / risk --------
ACCOUNT_CAPITAL=100000
RISK_PER_TRADE_PCT=0.75
MAX_DAILY_LOSS_PCT=2.0
MAX_OPEN_POSITIONS=5
MAX_TRADES_PER_DAY=10
COOLDOWN_AFTER_LOSSES=2

# -------- Market hours (IST) --------
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
SQUARE_OFF_TIME=15:20

# -------- Storage --------
DATABASE_URL=sqlite:///./data/billionaire.db

# -------- API / Dashboard --------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_ORIGIN=http://localhost:5173

# -------- Alerts (all optional) --------
ALERTS_CONSOLE=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# -------- Logging --------
LOG_LEVEL=INFO
LOG_DIR=./logs
