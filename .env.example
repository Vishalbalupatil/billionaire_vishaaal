# Zerodha Kite Connect
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
KITE_ACCESS_TOKEN=

# Trading mode: analysis | paper | live
TRADING_MODE=paper

# Risk settings
MAX_CAPITAL=100000
RISK_PER_TRADE_PCT=2.0
MAX_DAILY_LOSS_PCT=5.0
MAX_OPEN_POSITIONS=5

# Live trading unlock phrase (must type exactly to enable live)
LIVE_UNLOCK_PHRASE=I_ACCEPT_RISK

# Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
